# Harvester environment variables
# Copy to .env and fill in your values. Never commit .env.

# GitHub
GITHUB_TOKEN=ghp_...              # Fine-grained PAT: Issues + PRs write on watched repos
GITHUB_WEBHOOK_SECRET=...         # Shared secret for webhook signature verification

# LLM (scanner calls use Grok by default)
XAI_API_KEY=xai-...

# Telegram notifications
TELEGRAM_BOT_TOKEN=...
TELEGRAM_ALLOWED_CHAT_ID=...

# Ollama (optional — if scanners use local models)
OLLAMA_URL=http://localhost:11434

# Agent runner overrides (optional)
# HARVESTER_DEFAULT_TIMEOUT=30    # Minutes per item
# HARVESTER_DEFAULT_MAX_TURNS=50  # Claude Code max turns
# WORKSPACES_DIR=~/agent-workspaces
